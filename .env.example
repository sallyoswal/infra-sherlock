# Optional LLM provider selection: openai or openrouter
LLM_PROVIDER=openai

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenRouter settings (used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional cloud plugin mode: local or cloud
PLUGIN_MODE=local

# Optional AWS collector (read-only v1)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Optional Datadog collector (read-only v1)
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# Optional Slack notifications
SLACK_WEBHOOK_URL=
